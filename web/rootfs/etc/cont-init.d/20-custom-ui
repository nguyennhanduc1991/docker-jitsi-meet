#!/usr/bin/with-contenv bash

# Script cấu hình giao diện tùy chỉnh cho Jitsi Meet

echo "Cấu hình giao diện tùy chỉnh..."

# Copy các file cấu hình tùy chỉnh từ /custom (built into image)
if [ -f "/custom/interface_config.js" ]; then
    cp /custom/interface_config.js /config/interface_config.js
    echo "Đã copy interface_config.js từ /custom"
fi

if [ -f "/custom/custom.css" ]; then
    cp /custom/custom.css /config/custom.css
    echo "Đã copy custom.css từ /custom"
fi

if [ -f "/custom/index.html" ]; then
    cp /custom/index.html /config/index.html
    echo "Đã copy index.html từ /custom"
fi

if [ -f "/custom/jitsi-index.html" ]; then
    cp /custom/jitsi-index.html /config/jitsi-index.html
    echo "Đã copy jitsi-index.html từ /custom"
fi

if [ -f "/custom/nginx-custom.conf" ]; then
    cp /custom/nginx-custom.conf /etc/nginx/conf.d/nginx-custom.conf
    echo "Đã copy nginx-custom.conf từ /custom"
fi

# Tạo thư mục images nếu chưa có
mkdir -p /config/images

# Tạo file favicon mặc định nếu chưa có
if [ ! -f "/config/images/favicon.ico" ]; then
    echo "Tạo favicon mặc định..."
    # Có thể thêm logic tạo favicon ở đây
fi

# Tạo file logo mặc định nếu chưa có
if [ ! -f "/config/images/logo.png" ]; then
    echo "Tạo logo mặc định..."
    # Có thể thêm logic tạo logo ở đây
fi

# Copy các file NextGen CSS và JS từ /custom volume
if [ -f "/custom/nextgen-variables.css" ]; then
    cp /custom/nextgen-variables.css /config/nextgen-variables.css
    echo "Đã copy nextgen-variables.css từ /custom"
fi

if [ -f "/custom/nextgen-mixins.css" ]; then
    cp /custom/nextgen-mixins.css /config/nextgen-mixins.css
    echo "Đã copy nextgen-mixins.css từ /custom"
fi

if [ -f "/custom/nextgen-components.css" ]; then
    cp /custom/nextgen-components.css /config/nextgen-components.css
    echo "Đã copy nextgen-components.css từ /custom"
fi

if [ -f "/custom/nextgen-toolbar.css" ]; then
    cp /custom/nextgen-toolbar.css /config/nextgen-toolbar.css
    echo "Đã copy nextgen-toolbar.css từ /custom"
fi

if [ -f "/custom/nextgen-video.css" ]; then
    cp /custom/nextgen-video.css /config/nextgen-video.css
    echo "Đã copy nextgen-video.css từ /custom"
fi

if [ -f "/custom/nextgen-animations.css" ]; then
    cp /custom/nextgen-animations.css /config/nextgen-animations.css
    echo "Đã copy nextgen-animations.css từ /custom"
fi

if [ -f "/custom/nextgen-override.css" ]; then
    cp /custom/nextgen-override.css /config/nextgen-override.css
    echo "Đã copy nextgen-override.css từ /custom"
fi

if [ -f "/custom/nextgen-design-tokens.js" ]; then
    cp /custom/nextgen-design-tokens.js /config/nextgen-design-tokens.js
    echo "Đã copy nextgen-design-tokens.js từ /custom"
fi

if [ -f "/custom/nextgen-inject.js" ]; then
    cp /custom/nextgen-inject.js /config/nextgen-inject.js
    echo "Đã copy nextgen-inject.js từ /custom"
fi

# Copy welcome background image
if [ -f "/custom/images/welcome-background.png" ]; then
    cp /custom/images/welcome-background.png /config/images/welcome-background.png
    echo "Đã copy welcome-background.png từ /custom"
fi

# Copy NextGen CSS files trực tiếp vào thư mục Jitsi Meet
echo "Copy NextGen files trực tiếp vào Jitsi Meet directory..."

# Tạo thư mục css nếu chưa có
mkdir -p /usr/share/jitsi-meet/css
mkdir -p /usr/share/jitsi-meet/js

# Copy NextGen CSS files
if [ -f "/config/nextgen-variables.css" ]; then
    cp /config/nextgen-variables.css /usr/share/jitsi-meet/css/nextgen-variables.css
    echo "Đã copy nextgen-variables.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-mixins.css" ]; then
    cp /config/nextgen-mixins.css /usr/share/jitsi-meet/css/nextgen-mixins.css
    echo "Đã copy nextgen-mixins.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-components.css" ]; then
    cp /config/nextgen-components.css /usr/share/jitsi-meet/css/nextgen-components.css
    echo "Đã copy nextgen-components.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-toolbar.css" ]; then
    cp /config/nextgen-toolbar.css /usr/share/jitsi-meet/css/nextgen-toolbar.css
    echo "Đã copy nextgen-toolbar.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-video.css" ]; then
    cp /config/nextgen-video.css /usr/share/jitsi-meet/css/nextgen-video.css
    echo "Đã copy nextgen-video.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-animations.css" ]; then
    cp /config/nextgen-animations.css /usr/share/jitsi-meet/css/nextgen-animations.css
    echo "Đã copy nextgen-animations.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-override.css" ]; then
    cp /config/nextgen-override.css /usr/share/jitsi-meet/css/nextgen-override.css
    echo "Đã copy nextgen-override.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/custom.css" ]; then
    cp /config/custom.css /usr/share/jitsi-meet/css/custom.css
    echo "Đã copy custom.css vào /usr/share/jitsi-meet/css/"
fi

# Copy NextGen JS files
if [ -f "/config/nextgen-design-tokens.js" ]; then
    cp /config/nextgen-design-tokens.js /usr/share/jitsi-meet/js/nextgen-design-tokens.js
    echo "Đã copy nextgen-design-tokens.js vào /usr/share/jitsi-meet/js/"
fi

if [ -f "/config/nextgen-inject.js" ]; then
    cp /config/nextgen-inject.js /usr/share/jitsi-meet/js/nextgen-inject.js
    echo "Đã copy nextgen-inject.js vào /usr/share/jitsi-meet/js/"
fi

# Override main index.html
if [ -f "/config/jitsi-index.html" ]; then
    cp /config/jitsi-index.html /usr/share/jitsi-meet/index.html
    echo "Đã override index.html với NextGen Meet"
else
    # Fallback: Tạo index.html đơn giản nếu không có
    cat > /usr/share/jitsi-meet/index.html << 'EOF'
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NextGen Meet - Họp trực tuyến đẳng cấp</title>
    <link rel="stylesheet" href="css/all.css">
    <link rel="stylesheet" href="css/nextgen-override.css">
    <link rel="stylesheet" href="css/custom.css">
</head>
<body>
    <div id="react"></div>
    <script src="libs/lib-jitsi-meet.min.js"></script>
    <script src="libs/app.bundle.min.js"></script>
</body>
</html>
EOF
    echo "Đã tạo index.html fallback"
fi

# Override interface_config.js
if [ -f "/config/interface_config.js" ]; then
    cp /config/interface_config.js /usr/share/jitsi-meet/interface_config.js
    echo "Đã override interface_config.js với NextGen Meet"
fi

# Tạo file welcome background mặc định nếu chưa có
if [ ! -f "/config/images/welcome-background.png" ]; then
    echo "Tạo welcome background mặc định..."
    # Có thể thêm logic tạo background ở đây
fi

# Cấu hình nginx để serve NextGen Meet files
echo "Cấu hình nginx để serve NextGen Meet files..."

# Tạo nginx config đúng syntax
cat > /etc/nginx/conf.d/nextgen-meet.conf << 'EOF'
server {
    # Serve NextGen Meet CSS files
    location /css/nextgen-variables.css {
        alias /usr/share/jitsi-meet/css/nextgen-variables.css;
        add_header Content-Type text/css;
        expires 1d;
    }
    
    location /css/nextgen-mixins.css {
        alias /usr/share/jitsi-meet/css/nextgen-mixins.css;
        add_header Content-Type text/css;
        expires 1d;
    }
    
    location /css/nextgen-components.css {
        alias /usr/share/jitsi-meet/css/nextgen-components.css;
        add_header Content-Type text/css;
        expires 1d;
    }
    
    location /css/nextgen-toolbar.css {
        alias /usr/share/jitsi-meet/css/nextgen-toolbar.css;
        add_header Content-Type text/css;
        expires 1d;
    }
    
    location /css/nextgen-video.css {
        alias /usr/share/jitsi-meet/css/nextgen-video.css;
        add_header Content-Type text/css;
        expires 1d;
    }
    
    location /css/nextgen-animations.css {
        alias /usr/share/jitsi-meet/css/nextgen-animations.css;
        add_header Content-Type text/css;
        expires 1d;
    }
    
    location /css/nextgen-override.css {
        alias /usr/share/jitsi-meet/css/nextgen-override.css;
        add_header Content-Type text/css;
        expires 1d;
    }
    
    location /css/custom.css {
        alias /usr/share/jitsi-meet/css/custom.css;
        add_header Content-Type text/css;
        expires 1d;
    }
    
    # Serve NextGen Meet JS files
    location /js/nextgen-design-tokens.js {
        alias /usr/share/jitsi-meet/js/nextgen-design-tokens.js;
        add_header Content-Type application/javascript;
        expires 1d;
    }
    
    location /js/nextgen-inject.js {
        alias /usr/share/jitsi-meet/js/nextgen-inject.js;
        add_header Content-Type application/javascript;
        expires 1d;
    }
}
EOF

# Test nginx config
nginx -t
if [ $? -eq 0 ]; then
    echo "Nginx config test passed"
    # Reload nginx nếu đang chạy
    if [ -f "/var/run/nginx.pid" ]; then
        nginx -s reload
        echo "Đã reload nginx config"
    fi
else
    echo "Nginx config test failed"
fi

echo "NextGen Meet files đã được copy trực tiếp vào Jitsi Meet directory"

echo "Hoàn thành cấu hình giao diện tùy chỉnh!"
