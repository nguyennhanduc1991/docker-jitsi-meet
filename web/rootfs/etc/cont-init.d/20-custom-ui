#!/usr/bin/with-contenv bash

# Script cấu hình giao diện tùy chỉnh cho Jitsi Meet

echo "Cấu hình giao diện tùy chỉnh..."

# Copy các file cấu hình tùy chỉnh từ /custom (built into image)
if [ -f "/custom/interface_config.js" ]; then
    cp /custom/interface_config.js /config/interface_config.js
    echo "Đã copy interface_config.js từ /custom"
fi

if [ -f "/custom/custom.css" ]; then
    cp /custom/custom.css /config/custom.css
    echo "Đã copy custom.css từ /custom"
fi

if [ -f "/custom/index.html" ]; then
    cp /custom/index.html /config/index.html
    echo "Đã copy index.html từ /custom"
fi

if [ -f "/custom/jitsi-index.html" ]; then
    cp /custom/jitsi-index.html /config/jitsi-index.html
    echo "Đã copy jitsi-index.html từ /custom"
fi

if [ -f "/custom/nginx-custom.conf" ]; then
    cp /custom/nginx-custom.conf /etc/nginx/conf.d/nginx-custom.conf
    echo "Đã copy nginx-custom.conf từ /custom"
fi

# Tạo thư mục images nếu chưa có
mkdir -p /config/images

# Tạo file favicon mặc định nếu chưa có
if [ ! -f "/config/images/favicon.ico" ]; then
    echo "Tạo favicon mặc định..."
    # Có thể thêm logic tạo favicon ở đây
fi

# Tạo file logo mặc định nếu chưa có
if [ ! -f "/config/images/logo.png" ]; then
    echo "Tạo logo mặc định..."
    # Có thể thêm logic tạo logo ở đây
fi

# Copy các file NextGen CSS và JS từ /custom volume
if [ -f "/custom/nextgen-variables.css" ]; then
    cp /custom/nextgen-variables.css /config/nextgen-variables.css
    echo "Đã copy nextgen-variables.css từ /custom"
fi

if [ -f "/custom/nextgen-mixins.css" ]; then
    cp /custom/nextgen-mixins.css /config/nextgen-mixins.css
    echo "Đã copy nextgen-mixins.css từ /custom"
fi

if [ -f "/custom/nextgen-components.css" ]; then
    cp /custom/nextgen-components.css /config/nextgen-components.css
    echo "Đã copy nextgen-components.css từ /custom"
fi

if [ -f "/custom/nextgen-toolbar.css" ]; then
    cp /custom/nextgen-toolbar.css /config/nextgen-toolbar.css
    echo "Đã copy nextgen-toolbar.css từ /custom"
fi

if [ -f "/custom/nextgen-video.css" ]; then
    cp /custom/nextgen-video.css /config/nextgen-video.css
    echo "Đã copy nextgen-video.css từ /custom"
fi

if [ -f "/custom/nextgen-animations.css" ]; then
    cp /custom/nextgen-animations.css /config/nextgen-animations.css
    echo "Đã copy nextgen-animations.css từ /custom"
fi

if [ -f "/custom/nextgen-override.css" ]; then
    cp /custom/nextgen-override.css /config/nextgen-override.css
    echo "Đã copy nextgen-override.css từ /custom"
fi

if [ -f "/custom/nextgen-design-tokens.js" ]; then
    cp /custom/nextgen-design-tokens.js /config/nextgen-design-tokens.js
    echo "Đã copy nextgen-design-tokens.js từ /custom"
fi

if [ -f "/custom/nextgen-inject.js" ]; then
    cp /custom/nextgen-inject.js /config/nextgen-inject.js
    echo "Đã copy nextgen-inject.js từ /custom"
fi

# Copy welcome background image
if [ -f "/custom/images/welcome-background.png" ]; then
    cp /custom/images/welcome-background.png /config/images/welcome-background.png
    echo "Đã copy welcome-background.png từ /custom"
else
    echo "Không tìm thấy welcome-background.png trong /custom"
fi

# Copy welcome background vào thư mục Jitsi Meet
if [ -f "/config/images/welcome-background.png" ]; then
    cp /config/images/welcome-background.png /usr/share/jitsi-meet/images/welcome-background.png
    echo "Đã copy welcome-background.png vào /usr/share/jitsi-meet/images/"
else
    echo "Không tìm thấy welcome-background.png để copy"
fi

# Copy NextGen CSS files trực tiếp vào thư mục Jitsi Meet
echo "Copy NextGen files trực tiếp vào Jitsi Meet directory..."

# Tạo thư mục css nếu chưa có
mkdir -p /usr/share/jitsi-meet/css
mkdir -p /usr/share/jitsi-meet/js

# Copy NextGen CSS files
if [ -f "/config/nextgen-variables.css" ]; then
    cp /config/nextgen-variables.css /usr/share/jitsi-meet/css/nextgen-variables.css
    echo "Đã copy nextgen-variables.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-mixins.css" ]; then
    cp /config/nextgen-mixins.css /usr/share/jitsi-meet/css/nextgen-mixins.css
    echo "Đã copy nextgen-mixins.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-components.css" ]; then
    cp /config/nextgen-components.css /usr/share/jitsi-meet/css/nextgen-components.css
    echo "Đã copy nextgen-components.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-toolbar.css" ]; then
    cp /config/nextgen-toolbar.css /usr/share/jitsi-meet/css/nextgen-toolbar.css
    echo "Đã copy nextgen-toolbar.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-video.css" ]; then
    cp /config/nextgen-video.css /usr/share/jitsi-meet/css/nextgen-video.css
    echo "Đã copy nextgen-video.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-animations.css" ]; then
    cp /config/nextgen-animations.css /usr/share/jitsi-meet/css/nextgen-animations.css
    echo "Đã copy nextgen-animations.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/nextgen-override.css" ]; then
    cp /config/nextgen-override.css /usr/share/jitsi-meet/css/nextgen-override.css
    echo "Đã copy nextgen-override.css vào /usr/share/jitsi-meet/css/"
fi

if [ -f "/config/custom.css" ]; then
    cp /config/custom.css /usr/share/jitsi-meet/css/custom.css
    echo "Đã copy custom.css vào /usr/share/jitsi-meet/css/"
fi

# Copy NextGen JS files
if [ -f "/config/nextgen-design-tokens.js" ]; then
    cp /config/nextgen-design-tokens.js /usr/share/jitsi-meet/js/nextgen-design-tokens.js
    echo "Đã copy nextgen-design-tokens.js vào /usr/share/jitsi-meet/js/"
else
    # Tạo file JS mặc định nếu không có
    echo "Tạo nextgen-design-tokens.js mặc định..."
    cat > /usr/share/jitsi-meet/js/nextgen-design-tokens.js << 'EOF'
// NextGen Meet Design Tokens
window.nextgenTokens = {
    primary: '#1976d2',
    secondary: '#ffffff',
    accent: '#00bcd4'
};
EOF
fi

if [ -f "/config/nextgen-inject.js" ]; then
    cp /config/nextgen-inject.js /usr/share/jitsi-meet/js/nextgen-inject.js
    echo "Đã copy nextgen-inject.js vào /usr/share/jitsi-meet/js/"
else
    # Tạo file JS mặc định nếu không có
    echo "Tạo nextgen-inject.js mặc định..."
    cat > /usr/share/jitsi-meet/js/nextgen-inject.js << 'EOF'
// NextGen Meet Inject Script
console.log('NextGen Meet loaded');
EOF
fi

# Đảm bảo files có quyền đúng và nội dung đúng
chmod 644 /usr/share/jitsi-meet/js/nextgen-design-tokens.js
chmod 644 /usr/share/jitsi-meet/js/nextgen-inject.js

# Kiểm tra nội dung files
echo "Kiểm tra nội dung JS files..."
if [ -f "/usr/share/jitsi-meet/js/nextgen-design-tokens.js" ]; then
    echo "nextgen-design-tokens.js tồn tại"
    head -3 /usr/share/jitsi-meet/js/nextgen-design-tokens.js
else
    echo "nextgen-design-tokens.js không tồn tại"
fi

if [ -f "/usr/share/jitsi-meet/js/nextgen-inject.js" ]; then
    echo "nextgen-inject.js tồn tại"
    head -3 /usr/share/jitsi-meet/js/nextgen-inject.js
else
    echo "nextgen-inject.js không tồn tại"
fi

echo "Đã set quyền cho JS files"

# Override main index.html
if [ -f "/config/jitsi-index.html" ]; then
    cp /config/jitsi-index.html /usr/share/jitsi-meet/index.html
    echo "Đã override index.html với NextGen Meet"
else
    # Fallback: Tạo index.html đơn giản nếu không có
    cat > /usr/share/jitsi-meet/index.html << 'EOF'
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; img-src 'self' 'unsafe-inline' data: blob: https:; media-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' 'unsafe-inline' data: blob: https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' 'unsafe-inline' data: blob: https: wss: ws:; object-src 'none'; base-uri 'self';">
    <title>NextGen Meet - Họp trực tuyến đẳng cấp</title>
    <link rel="stylesheet" href="css/all.css">
    <link rel="stylesheet" href="css/nextgen-override.css">
    <link rel="stylesheet" href="css/custom.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<body>
    <div id="react"></div>
    <script src="libs/lib-jitsi-meet.min.js"></script>
    <script src="libs/app.bundle.min.js"></script>
</body>
</html>
EOF
    echo "Đã tạo index.html fallback"
fi

# Override interface_config.js
if [ -f "/config/interface_config.js" ]; then
    cp /config/interface_config.js /usr/share/jitsi-meet/interface_config.js
    echo "Đã override interface_config.js với NextGen Meet"
fi

# Tạo file welcome background mặc định nếu chưa có
if [ ! -f "/config/images/welcome-background.png" ]; then
    echo "Tạo welcome background mặc định..."
    # Có thể thêm logic tạo background ở đây
fi

# Tạo favicon mặc định nếu chưa có
if [ ! -f "/usr/share/jitsi-meet/images/favicon.ico" ]; then
    echo "Tạo favicon mặc định..."
    mkdir -p /usr/share/jitsi-meet/images
    # Copy favicon từ Jitsi Meet gốc nếu có
    if [ -f "/usr/share/jitsi-meet/favicon.ico" ]; then
        cp /usr/share/jitsi-meet/favicon.ico /usr/share/jitsi-meet/images/favicon.ico
        echo "Đã copy favicon từ Jitsi Meet gốc"
    else
        # Tạo favicon đơn giản
        echo "Tạo favicon placeholder..."
        # Copy favicon từ Jitsi Meet gốc nếu có
        if [ -f "/usr/share/jitsi-meet/favicon.ico" ]; then
            cp /usr/share/jitsi-meet/favicon.ico /usr/share/jitsi-meet/images/favicon.ico
            echo "Đã copy favicon từ Jitsi Meet gốc"
        else
            # Tạo favicon đơn giản bằng cách copy từ thư mục khác
            find /usr/share -name "favicon.ico" -type f 2>/dev/null | head -1 | xargs -I {} cp {} /usr/share/jitsi-meet/images/favicon.ico 2>/dev/null || echo "Không tìm thấy favicon để copy"
        fi
    fi
fi

# Xóa nginx config conflict và tạo config đúng cách
echo "Xóa nginx config conflict..."

# Xóa nginx-custom.conf nếu có conflict
if [ -f "/etc/nginx/conf.d/nginx-custom.conf" ]; then
    echo "Xóa nginx-custom.conf conflict..."
    rm -f /etc/nginx/conf.d/nginx-custom.conf
fi

# Tạo nginx config đúng syntax với server block
echo "Tạo nginx config đúng syntax với server block..."
cat > /etc/nginx/conf.d/nextgen-meet.conf << 'EOF'
server {
    listen 80;
    server_name _;
    
    # Serve NextGen Meet JS files
    location /js/nextgen-design-tokens.js {
        alias /usr/share/jitsi-meet/js/nextgen-design-tokens.js;
        add_header Content-Type application/javascript;
        expires 1d;
    }

    location /js/nextgen-inject.js {
        alias /usr/share/jitsi-meet/js/nextgen-inject.js;
        add_header Content-Type application/javascript;
        expires 1d;
    }

    # Serve interface_config.js
    location /interface_config.js {
        alias /usr/share/jitsi-meet/interface_config.js;
        add_header Content-Type application/javascript;
        expires 1d;
    }

    # Serve NextGen Meet images
    location /images/ {
        alias /usr/share/jitsi-meet/images/;
        expires 7d;
    }

    # Fallback: Serve JS files từ thư mục root
    location /nextgen-design-tokens.js {
        alias /usr/share/jitsi-meet/nextgen-design-tokens.js;
        add_header Content-Type application/javascript;
        expires 1d;
    }

    location /nextgen-inject.js {
        alias /usr/share/jitsi-meet/nextgen-inject.js;
        add_header Content-Type application/javascript;
        expires 1d;
    }
}
EOF

# Kiểm tra files tồn tại
echo "Kiểm tra files tồn tại..."
ls -la /usr/share/jitsi-meet/js/
ls -la /usr/share/jitsi-meet/interface_config.js

# Copy JS files vào thư mục nginx serve mặc định
echo "Copy JS files vào thư mục nginx serve mặc định..."

# Tạo thư mục js trong thư mục nginx serve mặc định
mkdir -p /usr/share/jitsi-meet/js

# Copy JS files vào thư mục nginx serve mặc định
cp /usr/share/jitsi-meet/js/nextgen-design-tokens.js /usr/share/jitsi-meet/js/nextgen-design-tokens.js
cp /usr/share/jitsi-meet/js/nextgen-inject.js /usr/share/jitsi-meet/js/nextgen-inject.js

# Đảm bảo files có quyền đúng
chmod 644 /usr/share/jitsi-meet/js/nextgen-design-tokens.js
chmod 644 /usr/share/jitsi-meet/js/nextgen-inject.js
chmod 644 /usr/share/jitsi-meet/interface_config.js

# Fallback: Copy JS files vào thư mục root để nginx serve mặc định
echo "Fallback: Copy JS files vào thư mục root..."
cp /usr/share/jitsi-meet/js/nextgen-design-tokens.js /usr/share/jitsi-meet/nextgen-design-tokens.js
cp /usr/share/jitsi-meet/js/nextgen-inject.js /usr/share/jitsi-meet/nextgen-inject.js
chmod 644 /usr/share/jitsi-meet/nextgen-design-tokens.js
chmod 644 /usr/share/jitsi-meet/nextgen-inject.js
echo "Đã copy JS files vào thư mục root làm fallback"

echo "Files đã được copy trực tiếp vào Jitsi Meet directory"

# Debug: Kiểm tra tất cả nginx configs
echo "Debug: Kiểm tra tất cả nginx configs..."
echo "=== Nginx configs trong /etc/nginx/conf.d/ ==="
ls -la /etc/nginx/conf.d/
echo "=== Nginx main config ==="
head -20 /etc/nginx/nginx.conf
echo "=== NextGen Meet config ==="
cat /etc/nginx/conf.d/nextgen-meet.conf

# Test nginx config với server block
echo "Test nginx config với server block..."
nginx -t
if [ $? -eq 0 ]; then
    echo "Nginx config test passed"
    # Reload nginx nếu đang chạy
    if [ -f "/var/run/nginx.pid" ]; then
        nginx -s reload
        echo "Đã reload nginx config"
    else
        echo "Nginx chưa chạy, sẽ start sau"
    fi
else
    echo "Nginx config test failed"
    echo "Xem nginx config:"
    cat /etc/nginx/conf.d/nextgen-meet.conf
fi

# Debug: Kiểm tra nội dung JS files
echo "Debug: Kiểm tra nội dung JS files..."
echo "=== nextgen-design-tokens.js ==="
head -5 /usr/share/jitsi-meet/js/nextgen-design-tokens.js
echo "=== nextgen-inject.js ==="
head -5 /usr/share/jitsi-meet/js/nextgen-inject.js
echo "=== interface_config.js ==="
head -5 /usr/share/jitsi-meet/interface_config.js

# Debug: Kiểm tra CSS files
echo "Debug: Kiểm tra CSS files..."
echo "=== nextgen-override.css ==="
head -10 /usr/share/jitsi-meet/css/nextgen-override.css
echo "=== custom.css ==="
head -10 /usr/share/jitsi-meet/css/custom.css

# Debug: Kiểm tra background image
echo "Debug: Kiểm tra background image..."
ls -la /usr/share/jitsi-meet/images/
if [ -f "/usr/share/jitsi-meet/images/welcome-background.png" ]; then
    echo "welcome-background.png tồn tại"
    file /usr/share/jitsi-meet/images/welcome-background.png
else
    echo "welcome-background.png không tồn tại"
fi

# Test JS files accessible
echo "Test JS files accessible..."
echo "Testing nextgen-design-tokens.js..."
curl -I http://localhost/js/nextgen-design-tokens.js 2>/dev/null | head -3 || echo "Cannot test locally"
echo "Testing nextgen-inject.js..."
curl -I http://localhost/js/nextgen-inject.js 2>/dev/null | head -3 || echo "Cannot test locally"
echo "Testing interface_config.js..."
curl -I http://localhost/interface_config.js 2>/dev/null | head -3 || echo "Cannot test locally"

# Test nội dung JS files
echo "Test nội dung JS files..."
echo "=== nextgen-design-tokens.js content ==="
head -3 /usr/share/jitsi-meet/js/nextgen-design-tokens.js
echo "=== nextgen-inject.js content ==="
head -3 /usr/share/jitsi-meet/js/nextgen-inject.js
echo "=== interface_config.js content ==="
head -3 /usr/share/jitsi-meet/interface_config.js

echo "NextGen Meet files đã được copy trực tiếp vào Jitsi Meet directory"

echo "NextGen Meet files đã được copy trực tiếp vào Jitsi Meet directory"

echo "Hoàn thành cấu hình giao diện tùy chỉnh!"
